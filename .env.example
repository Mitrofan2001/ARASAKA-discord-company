OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4.1-mini

# slash command 註冊與接收用（可指定任一隻，例如 Planner）
COMMAND_BOT_TOKEN=貼你指定接收slash的bot token
COMMAND_BOT_CLIENT_ID=貼同一隻bot的application id
GUILD_ID=你的discord伺服器id

# @提及回覆時要讀幾則歷史訊息（可選，預設20）
MENTION_HISTORY_LIMIT=20

BOT_PLANNER_TOKEN=token1
BOT_CONSULTANT_TOKEN=token2
BOT_LEGAL_TOKEN=token3
BOT_FINANCE_TOKEN=token4
BOT_MARKETING_TOKEN=token5
BOT_DESIGN_TOKEN=token6
BOT_MENTOR_TOKEN=token7
